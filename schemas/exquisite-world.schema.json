{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Exquisite World Website Data",
  "type": "object",
  "required": [
    "project",
    "taglines",
    "characters",
    "locations",
    "rituals"
  ],
  "properties": {
    "project": {
      "type": "string"
    },
    "taglines": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "characters": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "role",
          "loves"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "role": {
            "type": "string"
          },
          "loves": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "locations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "rituals": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    }
  }
}